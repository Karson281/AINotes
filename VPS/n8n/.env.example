# n8n 配置 — 必要
N8N_ENCRYPTION_KEY=

# Webhook 外部訪問（如用 Traefik subdomain）
# WEBHOOK_URL=https://n8n.yourdomain.com

# n8n 基本認證（optional，建議用 Traefik Basic Auth 代替）
# N8N_BASIC_AUTH_ACTIVE=true
# N8N_BASIC_AUTH_USER=admin
# N8N_BASIC_AUTH_PASSWORD=

# Timezone
GENERIC_TIMEZONE=Asia/Hong_Kong
N8N_DEFAULT_TIMEZONE=Asia/Hong_Kong
